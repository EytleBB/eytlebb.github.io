#!/bin/sh
node -e "
const fs = require('fs');

// Gallery index
if (fs.existsSync('images/gallery')) {
  const exts = new Set(['.png', '.jpg', '.jpeg', '.gif', '.webp']);
  const files = fs.readdirSync('images/gallery')
    .filter(f => exts.has(f.slice(f.lastIndexOf('.')).toLowerCase()))
    .sort();
  fs.writeFileSync('images/gallery/index.json', JSON.stringify(files));
}

// Logs index
if (fs.existsSync('logs')) {
  const dates = fs.readdirSync('logs')
    .filter(f => /^\d{4}-\d{2}-\d{2}\.txt\$/.test(f))
    .map(f => f.slice(0, -4))
    .sort().reverse();
  fs.writeFileSync('logs/index.json', JSON.stringify(dates));
}
"

git add images/gallery/index.json logs/index.json 2>/dev/null
exit 0
